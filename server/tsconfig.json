{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
        "@/*": ["src/*"],
        "@controllers/*": ["src/controllers/*"],
        "@middleware/*": ["src/middleware/*"],
        "@routes/*": ["src/routes/*"],
        "@config/*": ["src/config/*"],
        "@models/*": ["src/models/*"]
    }
  }
}
